generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth / Account ----------

enum Plan {
  STARTER
  PRO
  AGENCY
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String  @map("password_hash")
  name         String
  businessName String? @map("business_name")
  phone        String?
  address      String?
  gstin        String?
  logoUrl      String? @map("logo_url")

  plan            Plan          @default(STARTER)
  planCycle       BillingCycle? @map("plan_cycle")
  planActivatedAt DateTime?     @map("plan_activated_at")
  planRenewsAt    DateTime?     @map("plan_renews_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  clients             Client[]
  proposals           Proposal[]
  invoices            Invoice[]
  invoiceItems        InvoiceItem[]
  payments            Payment[]
  activityLogs        ActivityLog[]
  planOrders          PlanOrder[]

  @@map("users")
}

// Pending/paid plan-upgrade orders (Razorpay payment links)
model PlanOrder {
  id              String       @id @default(cuid())
  userId          String       @map("user_id")
  plan            Plan
  cycle           BillingCycle
  amount          Decimal      @db.Decimal(12, 2)
  razorpayLinkId  String?      @map("razorpay_link_id")
  linkUrl         String?      @map("link_url")
  status          PaymentStatus @default(CREATED)
  paidAt          DateTime?    @map("paid_at")
  createdAt       DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("plan_orders")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  userAgent String?   @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ---------- Clients ----------

enum ClientStatus {
  ACTIVE
  INACTIVE
}

model Client {
  id      String       @id @default(cuid())
  userId  String       @map("user_id")
  name    String
  company String?
  email   String?
  phone   String?
  address String?
  notes   String?
  status  ClientStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  proposals Proposal[]
  invoices  Invoice[]

  @@index([userId])
  @@index([userId, status])
  @@map("clients")
}

// ---------- Proposals ----------

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum ProposalTone {
  FORMAL
  CASUAL
}

enum ProposalLanguage {
  ENGLISH
  HINGLISH
}

model Proposal {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  clientId    String           @map("client_id")
  title       String
  brief       String // raw project brief entered by the user
  budgetRange String?          @map("budget_range")
  timeline    String?
  tone        ProposalTone     @default(FORMAL)
  language    ProposalLanguage @default(ENGLISH)
  content     Json? // structured AI output (sections)
  rawOutput   String?          @map("raw_output") // raw model response for regeneration
  status      ProposalStatus   @default(DRAFT)
  sentAt      DateTime?        @map("sent_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
  @@map("proposals")
}

// ---------- Invoices ----------

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

enum GstType {
  NONE
  CGST_SGST // intra-state
  IGST // inter-state
}

enum RecurringInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

model Invoice {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  clientId      String        @map("client_id")
  invoiceNumber String        @map("invoice_number")
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime      @default(now()) @map("issue_date")
  dueDate       DateTime?     @map("due_date")
  currency      String        @default("INR")

  subtotal   Decimal @default(0) @db.Decimal(12, 2)
  gstType    GstType @default(NONE) @map("gst_type")
  gstRate    Decimal @default(0) @map("gst_rate") @db.Decimal(5, 2) // total GST %
  cgstAmount Decimal @default(0) @map("cgst_amount") @db.Decimal(12, 2)
  sgstAmount Decimal @default(0) @map("sgst_amount") @db.Decimal(12, 2)
  igstAmount Decimal @default(0) @map("igst_amount") @db.Decimal(12, 2)
  total      Decimal @default(0) @db.Decimal(12, 2)

  notes       String?
  clientGstin String? @map("client_gstin")

  razorpayOrderId String? @map("razorpay_order_id")
  paymentLinkId   String? @map("payment_link_id")
  paymentLinkUrl  String? @map("payment_link_url")

  // Recurring invoices: the template invoice auto-generates the next one
  // (as a draft) when nextRecurringDate arrives.
  isRecurring       Boolean            @default(false) @map("is_recurring")
  recurringInterval RecurringInterval? @map("recurring_interval")
  nextRecurringDate DateTime?          @map("next_recurring_date")
  parentInvoiceId   String?            @map("parent_invoice_id")

  sentAt    DateTime? @map("sent_at")
  paidAt    DateTime? @map("paid_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items    InvoiceItem[]
  payments Payment[]

  @@unique([userId, invoiceNumber])
  @@index([userId])
  @@index([clientId])
  @@index([userId, status])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String  @map("invoice_id")
  userId      String  @map("user_id")
  description String
  quantity    Decimal @default(1) @db.Decimal(10, 2)
  rate        Decimal @default(0) @db.Decimal(12, 2)
  amount      Decimal @default(0) @db.Decimal(12, 2)
  sortOrder   Int     @default(0) @map("sort_order")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([userId])
  @@map("invoice_items")
}

// ---------- Payments ----------

enum PaymentStatus {
  CREATED
  CAPTURED
  FAILED
  REFUNDED
}

model Payment {
  id                String        @id @default(cuid())
  userId            String        @map("user_id")
  invoiceId         String        @map("invoice_id")
  razorpayPaymentId String?       @unique @map("razorpay_payment_id")
  razorpayOrderId   String?       @map("razorpay_order_id")
  amount            Decimal       @db.Decimal(12, 2)
  currency          String        @default("INR")
  method            String?
  status            PaymentStatus @default(CREATED)
  paidAt            DateTime?     @map("paid_at")
  rawPayload        Json?         @map("raw_payload")

  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([invoiceId])
  @@map("payments")
}

// ---------- Activity ----------

model ActivityLog {
  id         String  @id @default(cuid())
  userId     String  @map("user_id")
  type       String // e.g. "client.created", "invoice.paid", "proposal.sent"
  entityType String? @map("entity_type")
  entityId   String? @map("entity_id")
  message    String

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("activity_log")
}
