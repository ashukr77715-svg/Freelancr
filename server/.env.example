# Server
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/freelance_saas

# Auth — generate with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Frontend origin (CORS + links in emails)
CLIENT_URL=http://localhost:5173

# Email (optional in dev — reset links are logged to the server console if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="FreelanceHQ <no-reply@yourdomain.com>"

# AI (build step 4)
ANTHROPIC_API_KEY=

# Razorpay (build step 5)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
